{
    "name": "Gavel Judging System",
    "description": "An awesome judging system for hackathons",
    "repository": "https://github.com/skelston/gavel2",
    "success_url": "/admin",
    "keywords": ["gavel", "python", "flask"],
    "addons": [
      "heroku-postgresql:essential-0",
      "heroku-redis:mini"
    ],
    "formation": {
      "web": { "quantity": 1, "size": "eco" },
      "worker": { "quantity": 1, "size": "eco" }
    },
    "env": {
      "ADMIN_PASSWORD": {
        "description": "Password for the administrator account.",
        "required": true
      },
      "SECRET_KEY": {
        "description": "Secret key used to hash requests and keys.",
        "generator": "secret"
      },
      "BASE_URL": {
        "description": "The base URL of the app.",
        "value": "https://<app-name>.herokuapp.com"
      },
      "VIRTUAL_EVENT": {
        "description": "Enable virtual event features if set to true.",
        "value": "false"
      },
      "DISABLE_EMAIL": {
        "description": "Email sending is disabled if set to true.",
        "value": "false"
      },
      "EMAIL_FROM": {
        "description": "Who the emails are sent from. Format: Sender Name <sender@email.com>",
        "value": "_unused_"
      },
      "EMAIL_PROVIDER": {
        "description": "Email service (smtp, mailgun, sendgrid).",
        "value": "smtp"
      },
      "EMAIL_USER": { "value": "_unused_" },
      "EMAIL_PASSWORD": { "value": "_unused_" },
      "EMAIL_HOST": { "value": "smtp.gmail.com" },
      "EMAIL_PORT": { "value": "587" },
      "SENDGRID_API_KEY": { "value": "_unused_" },
      "MAILGUN_DOMAIN": { "value": "_unused_" },
      "MAILGUN_API_KEY": { "value": "_unused_" },
      "IGNORE_CONFIG_FILE": {
        "description": "MUST be set to true in order for these environment variables to work.",
        "value": "true"
      }
    }
  }
  