{
  "name": "gavel",
  "version": "1.0.0",
  "description": "Hackathon Judging System",
  "repository": "git@github.com:weareasterisk/gavel.git",
  "private": false,
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=11.0.0"
  },
  "scripts": {
    "build": "cross-env NODE_ENV=production postcss gavel/static/css/tailwind.css -o gavel/static/generated.css",
    "build:watch": "cross-env NODE_ENV=development postcss gavel/static/css/tailwind.css -o gavel/static/generated.css -w"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.10",
    "autoprefixer": "^10.4.21",
    "cross-env": "^7.0.3",
    "cssnano": "^5.1.15",
    "postcss": "^8.5.6",
    "postcss-cli": "^11.0.1",
    "postcss-import": "^13.0.0",
    "postcss-loader": "^4.3.0",
    "postcss-preset-env": "^7.8.3",
    "postcss-url": "^10.1.3",
    "tailwindcss": "^3.4.17"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "@tailwindcss/nesting": "^0.0.0-insiders.565cd3e",
    "tinycolor2": "^1.4.1"
  }
}
