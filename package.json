{
  "name": "gavel",
  "version": "1.0.0",
  "description": "Hackathon Judging System",
  "repository": "git@github.com:weareasterisk/gavel.git",
  "private": false,
  "scripts": {
    "build": "cross-env NODE_ENV=production postcss gavel/static/css/tailwind.scss -o gavel/static/generated.scss",
    "build:watch": "cross-env NODE_ENV=development postcss gavel/static/css/tailwind.scss -o gavel/static/generated.scss -w"
  },
  "devDependencies": {
    "@fullhuman/postcss-purgecss": "^2.3.0",
    "@tailwindcss/forms": "^0.3.4",
    "autoprefixer": "^10.4.21",
    "cross-env": "^7.0.3",
    "cssnano": "^4.1.11",
    "postcss": "^8.5.6",
    "postcss-cli": "^7.1.2",
    "postcss-import": "^12.0.1",
    "postcss-loader": "^3.0.0",
    "postcss-modules": "^1.5.0",
    "postcss-nested": "^4.2.3",
    "postcss-preset-env": "^6.7.0",
    "postcss-scss": "^2.1.1",
    "postcss-url": "^8.0.0",
    "tailwindcss": "^2.2.16"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "dependencies": {
    "tinycolor2": "^1.4.1"
  }
}
